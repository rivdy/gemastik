# Salin file ini jadi .env dan isi API key kalian sendiri.
# JANGAN commit file .env yang asli — pastikan .env ada di .gitignore.

# DisGeNET (butuh registrasi + lisensi akademik gratis di https://www.disgenet.com/)
DISGENET_API_KEY=

# PharmGKB / ClinPGx (https://api.clinpgx.org/)
CLINPGX_API_KEY=

# OMIM (butuh registrasi di https://www.omim.org/api)
OMIM_API_KEY=

# NCBI E-utilities (opsional, tapi menaikkan rate limit kalau nanti pakai PubMed/Entrez)
NCBI_API_KEY=
